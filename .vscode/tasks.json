{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "compile",
      "problemMatcher": ["$tsc"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "type": "npm",
      "script": "watch",
      "problemMatcher": ["$tsc-watch"],
      "group": "build",
      "isBackground": true
    },
    {
      "label": "Run All Tests",
      "type": "shell",
      "command": "npx vitest",
      "group": "test",
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Run Current Test File",
      "type": "shell",
      "command": "npx vitest ${relativeFile}",
      "group": "test",
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}