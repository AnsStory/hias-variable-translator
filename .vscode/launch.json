{
  "version": "0.2.0",
  "compounds": [
    {
      "name": "Extension (Watch)",
      "configurations": ["Run Extension"],
      "stopAll": true
    }
  ],
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ],
      "preLaunchTask": "npm: compile"
    }
  ]
}
